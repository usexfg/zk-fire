# COLD Deposits API Configuration

# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,https://usexfg.org

# Fuego Daemon RPC
FUEGO_MAINNET_RPC=http://localhost:18180
FUEGO_TESTNET_RPC=http://localhost:28081

# Arbitrum RPC
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Ethereum RPC (for L1 queries)
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# API Verifier Wallet
API_VERIFIER_PRIVATE_KEY=your_private_key_here

# Contract Addresses (Testnet)
COLD_VERIFIER_ADDRESS=0x...
CD_TOKEN_ADDRESS=0x...

# Security
JWT_SECRET=your_jwt_secret_here
